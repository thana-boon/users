# =============================================================
# SchoolOS - Student & Teacher Records  ·  environment sample
# Copy to `.env` and fill real values. NEVER commit the real .env.
# =============================================================

# --- Database (PostgreSQL) ---
# When running the app inside docker-compose, host = "postgres".
# When running `npm run dev` on Windows against the compose DB, host = "localhost".
DATABASE_URL="postgres://schoolos:schoolos@localhost:5002/users"
POSTGRES_DB="users"
POSTGRES_USER="schoolos"
POSTGRES_PASSWORD="schoolos"

# --- Field encryption (AES-256-GCM) ---
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: this key lives OUTSIDE the database. If leaked, every stored
# password / citizen_id / income can be decrypted. Rotate via re-encrypt.
FIELD_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTE_KEY"

# --- Session JWT (schoolos_token cookie, HS256) ---
# This app signs its own session token on local login (teacher-login /
# student-login) and sets the `schoolos_token` cookie; middleware verifies it.
# No external SSO — JWT_SECRET only needs to be a long random secret for THIS app.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
# Session token lifetime. An 8h absolute cap from the original login is also
# enforced via the `login_at` claim, independent of this sliding exp.
JWT_EXPIRES_IN="8h"

# Email domain used to generate student login emails from student_code.
STUDENT_EMAIL_DOMAIN="sukhon.ac.th"
