# =============================================================
# SchoolOS - Student & Teacher Records  ·  environment sample
# Copy to `.env` and fill real values. NEVER commit the real .env.
# =============================================================

# --- Database (PostgreSQL) ---
# This stack does NOT run a Postgres of its own. It connects to the school's
# existing `postgres-core` container over the external `school-net` network,
# as the per-module role/database `users`.
#
# Used by every compose service. Host = the DB container name on school-net.
# Compose aborts if it is unset — there is no default.
DATABASE_URL_INTERNAL="postgres://users:THE_USERS_ROLE_PASSWORD@postgres-core:5432/users"
# Used only when running `npm run dev` on the host (outside compose), via the
# port postgres-core publishes.
DATABASE_URL="postgres://users:THE_USERS_ROLE_PASSWORD@localhost:5432/users"

# --- Field encryption (AES-256-GCM) ---
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: this key lives OUTSIDE the database. If leaked, every stored
# password / citizen_id / income can be decrypted. Rotate via re-encrypt.
FIELD_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTE_KEY"

# --- Session JWT (schoolos_token cookie, HS256) ---
# This app signs its own session token on local login (teacher-login /
# student-login) and sets the `schoolos_token` cookie; middleware verifies it.
# No external SSO — JWT_SECRET only needs to be a long random secret for THIS app.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
# Session token lifetime. An 8h absolute cap from the original login is also
# enforced via the `login_at` claim, independent of this sliding exp.
JWT_EXPIRES_IN="8h"
# Set the `Secure` flag on the session cookie. Secure-by-DEFAULT (true) so the
# token is never sent in the clear over HTTPS. Set to false ONLY for a plain-HTTP
# LAN deploy (e.g. http://192.168.x.x:3002) — otherwise the browser drops the
# cookie and login "succeeds" but never redirects. Never false on HTTPS/internet.
COOKIE_SECURE="true"

# Number of trusted reverse proxies in front of this app. Used to pick the real
# client IP from X-Forwarded-For (counted from the RIGHT) so a caller cannot
# forge it to poison audit logs / bypass per-IP rate limiting. 1 = one gateway
# (the deployed default). Set 0 if the app is directly exposed (no proxy).
TRUSTED_PROXY_COUNT="1"

# Email domain used to generate student login emails from student_code.
STUDENT_EMAIL_DOMAIN="sukhon.ac.th"

# --- Bootstrap admin login ---
# The app creates this teacher_code as a teacher-admin at startup, but ONLY when
# the database holds no active teacher-admin at all (fresh server). Once any
# admin exists these are ignored, so a password changed in the UI survives a
# redeploy. NAME is optional. Change the password after the first login — it is
# stored encrypted, but this file holds it in plaintext.
SEED_ADMIN_CODE="T00001"
SEED_ADMIN_PASSWORD="CHOOSE_A_STRONG_ADMIN_PASSWORD"
SEED_ADMIN_NAME="ผู้ดูแล ระบบ"
