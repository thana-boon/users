# =============================================================
# SchoolOS - Student & Teacher Records  ·  environment sample
# Copy to `.env` and fill real values. NEVER commit the real .env.
# =============================================================

# --- Database (PostgreSQL) ---
# When running the app inside docker-compose, host = "postgres".
# When running `npm run dev` on Windows against the compose DB, host = "localhost".
DATABASE_URL="postgres://schoolos:schoolos@localhost:5432/users"
POSTGRES_DB="users"
POSTGRES_USER="schoolos"
POSTGRES_PASSWORD="schoolos"

# --- Field encryption (AES-256-GCM) ---
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: this key lives OUTSIDE the database. If leaked, every stored
# password / citizen_id / income can be decrypted. Rotate via re-encrypt.
FIELD_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTE_KEY"

# --- SSO / JWT (schoolos_token cookie, HS256, shared with schoolos-portal) ---
# The portal signs the token and sets the `schoolos_token` cookie; this module
# only verifies it. JWT_SECRET MUST match the portal's value byte-for-byte
# (same secret across every app-service) or every SSO login is rejected. Verify:
#   docker exec schoolos-portal sh -c 'printenv JWT_SECRET | tr -d "\n" | md5sum'
#   docker exec schoolos-users  sh -c 'printenv JWT_SECRET | tr -d "\n" | md5sum'
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
# Local login (dev-token / teacher-login) exp. The 8h ABSOLUTE cap from the
# original login is enforced separately via the `login_at` claim, regardless.
JWT_EXPIRES_IN="8h"

# /api/auth/dev-token (mock-role token), for testing this module WITHOUT the
# portal. Set to "false" in any environment where the real portal is wired in.
# The /login page ALWAYS offers the real รหัสครู+password form (teacher-login);
# this flag only gates the extra "Dev quick login" buttons on that page.
ENABLE_DEV_TOKEN="true"
# Client-side mirror of the flag above — must be "true" for the dev quick-login
# buttons to render on /login (Next.js only exposes NEXT_PUBLIC_* to the browser).
NEXT_PUBLIC_ENABLE_DEV_TOKEN="true"

# Email domain used to generate student login emails from student_code.
STUDENT_EMAIL_DOMAIN="sukhon.ac.th"
