{
  "name": "schoolos-users",
  "version": "1.0.0",
  "private": true,
  "description": "SchoolOS - Student & Teacher Records Module (Sukhondheerawidh School)",
  "scripts": {
    "predev": "node scripts/copy-mediapipe.mjs",
    "dev": "next dev -p 3002",
    "prebuild": "node scripts/copy-mediapipe.mjs",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "seed:students": "tsx scripts/migrate-students.ts",
    "seed:teachers": "tsx scripts/migrate-teachers.ts",
    "seed": "npm run seed:teachers && npm run seed:students",
    "admin:create": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "next": "^15.5.20",
    "postgres": "^3.4.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
